# Application Environment Configuration
# Copy this file to .env and update with your actual values

# Application
APP_NAME="RTTC 2026 Registration Portal"
APP_ENV=development
APP_URL=http://localhost/mycode/PROJECTS/RTTC_2026/

# Database
DB_HOST=localhost
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=rangiatt_2026
DB_CHARSET=utf8mb4

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USERNAME=admissionrttc@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=admissionrttc@gmail.com
SMTP_FROM_NAME="RTTC Admissions"

# Payment (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_AMOUNT=50000

# Session
SESSION_LIFETIME=3600

# Security
CSRF_TOKEN_NAME=csrf_token
PASSWORD_MIN_LENGTH=8

# OTP
OTP_EXPIRY=600

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf
